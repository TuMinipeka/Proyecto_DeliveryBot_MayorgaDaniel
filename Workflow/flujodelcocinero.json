    {
      "parameters": {
        "jsCode": "const idPedido = $('Parsear comando/estado').item.json.id_pedido;\nconst nuevoEstado = $('Parsear comando/estado').item.json.nuevo_estado;\nconst idUsuario = $('Buscar pedido').item.json.id_usuario; // viene del Get rows PEDIDOS\n\n// Emoji según estado\nconst emojis = {\n  'Recibido':    '📋',\n  'Preparación': '👨‍🍳',\n  'En camino':   '🛵',\n  'Entregado':   '✅'\n};\n\nconst emoji = emojis[nuevoEstado] || '📌';\n\nconst mensajeCliente = `${emoji} *Actualización de tu pedido*\\n\\n📋 N° ${idPedido}\\n\\nEstado actual: *${nuevoEstado}*`;\nconst mensajeAdmin = `✅ Estado de *${idPedido}* actualizado a *${nuevoEstado}*.`;\n\nreturn [{\n  json: {\n    id_usuario: idUsuario,\n    mensaje_cliente: mensajeCliente,\n    mensaje_admin: mensajeAdmin\n  }\n}];"
      },
