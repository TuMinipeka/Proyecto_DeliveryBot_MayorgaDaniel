    {
      "parameters": {
        "jsCode": "const texto = $json.message.text.trim();\nconst chatAdmin = $json.message.chat.id;\n\nconst partes = texto.split(' ');\n\nif (partes.length < 3) {\n  return [{\n    json: {\n      valido: false,\n      chat_admin: chatAdmin,\n      mensaje_error: `❌ *Formato incorrecto*\\n\\nUso correcto:\\n\\`/estado PED-xxx-xxx NuevoEstado\\`\\n\\nEjemplo:\\n\\`/estado PED-8907728238-1234567890 Preparación\\`\\n\\nEscribe /ayuda para ver los estados válidos.`\n    }\n  }];\n}\n\nconst id_pedido = partes[1];\nconst nuevo_estado = partes.slice(2).join(' ');\n\nconst estados_validos = ['Recibido', 'Preparación', 'En camino', 'Entregado'];\n\nif (!estados_validos.includes(nuevo_estado)) {\n  return [{\n    json: {\n      valido: false,\n      chat_admin: chatAdmin,\n      mensaje_error: `❌ *Estado inválido:* \\`${nuevo_estado}\\`\\n\\nEstados permitidos:\\n• \\`Recibido\\`\\n• \\`Preparación\\`\\n• \\`En camino\\`\\n• \\`Entregado\\`\\n\\nEjemplo correcto:\\n\\`/estado PED-xxx-xxx En camino\\``\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    valido: true,\n    id_pedido: id_pedido,\n    nuevo_estado: nuevo_estado,\n    chat_admin: chatAdmin\n  }\n}];"
      },
